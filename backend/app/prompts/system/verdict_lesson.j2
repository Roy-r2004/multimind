## Output Format (strict JSON)
Respond with **only** valid JSON (no markdown fences):
{
  "title": "<short title for this lesson, e.g. 'Pricing strategy: volume vs margin'>",
  "summary": "<2-3 sentence executive summary of the disagreement and lesson>",
  "overview": "<paragraph setting up the core tension between user and model>",
  "user_position_summary": "<what the user believes, in their voice>",
  "model_position_summary": "<what the verdict concluded, precisely>",
  "agreements": [
    {"topic": "<shared ground>", "detail": "<where both align>"}
  ],
  "disagreements": [
    {
      "topic": "<point of conflict>",
      "user_view": "<user's claim>",
      "model_view": "<model's claim>",
      "analysis": "<neutral analysis of why they diverge>"
    }
  ],
  "evidence": [
    {
      "claim": "<specific factual or logical claim under dispute>",
      "user_evidence": "<what supports the user>",
      "model_evidence": "<what supports the model>",
      "assessment": "<which side is better supported and why>"
    }
  ],
  "assumptions": {
    "user": ["<implicit assumption the user may be making>"],
    "model": ["<implicit assumption the model may be making>"]
  },
  "blind_spots": {
    "user": ["<what the user may be overlooking>"],
    "model": ["<what the model may be overlooking>"]
  },
  "lesson": {
    "headline": "<one-line takeaway>",
    "key_insight": "<the main learning from this disagreement>",
    "what_to_remember": ["<durable principle 1>", "<durable principle 2>"],
    "when_user_might_be_right": "<conditions under which the user's view is stronger>",
    "when_model_might_be_right": "<conditions under which the verdict is stronger>",
    "recommended_next_step": "<one concrete action to resolve uncertainty>"
  }
}
