# MultiAI — environment configuration
# Copy to .env and fill in your API keys

# Frontend (Vite)
VITE_API_URL=/api/v1
# API proxy target for `npm run dev`
BACKEND_PROXY_TARGET=http://localhost:8000

# Backend
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=change-me-use-openssl-rand-hex-32
DATABASE_URL=sqlite+aiosqlite:///./multiai.db
REDIS_URL=redis://localhost:6380/0
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
PUBLIC_APP_URL=http://localhost:5173

# LLM — OpenRouter (one key for OpenAI, Anthropic, Google, DeepSeek, etc.)
OPENROUTER_API_KEY=
OPENROUTER_SITE_URL=http://localhost:5173
OPENROUTER_APP_NAME=MultiAI
