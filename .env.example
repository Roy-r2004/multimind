# MultiAI — environment configuration
# Copy to .env and fill in your API keys

# Frontend (Vite / TanStack Start)
VITE_API_URL=/api/v1
# Dev proxy + Docker/Render web container runtime proxy to the API
BACKEND_PROXY_TARGET=http://localhost:8000

# Backend
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=change-me-use-openssl-rand-hex-32
DATABASE_URL=sqlite+aiosqlite:///./multiai.db
# Docker Compose / Render Postgres example:
# DATABASE_URL=postgresql+asyncpg://multiai:multiai@postgres:5432/multiai
REDIS_URL=redis://localhost:6380/0
# ARQ needs a large finite timeout to keep its in-progress lock alive. Seven days is effectively
# unbounded for normal census runs; the progress watchdog still detects crawl loops.
SCRAPING_WORKER_JOB_TIMEOUT_SECONDS=604800
SCRAPING_LOOP_WATCHDOG_ENABLED=true
SCRAPING_LOOP_WATCHDOG_REPEATED_TASK_STOP_THRESHOLD=3
SCRAPING_LOOP_WATCHDOG_STAGNANT_ROUND_WARNING_THRESHOLD=2
SCRAPING_LOOP_WATCHDOG_STAGNANT_ROUND_STOP_THRESHOLD=5
SCRAPING_LOOP_WATCHDOG_URL_PATTERN_WARNING_THRESHOLD=250
SCRAPING_LOOP_WATCHDOG_REPEATED_CONTENT_STOP_THRESHOLD=8
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:3080,https://multiai-web.onrender.com
PUBLIC_APP_URL=http://localhost:3000

# LLM — OpenRouter (one key for all models)
OPENROUTER_API_KEY=
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=MultiAI

# Real source discovery — Serper is the default provider
SOURCE_DISCOVERY_PROVIDER=serper
SERPER_API_KEY=
SERPER_SEARCH_BASE_URL=https://google.serper.dev/search
SERPER_SEARCH_TIMEOUT_SECONDS=10
SERPER_SEARCH_RESULTS_PER_QUERY=10
SERPER_SEARCH_MAX_QUERIES_PER_DISCOVERY=4

# Secure source retrieval (internal service only; no arbitrary public fetch endpoint)
SOURCE_RETRIEVAL_USER_AGENT=MultiMindSourceRetrieval/1.0 (+https://multimind.local/source-retrieval)
SOURCE_RETRIEVAL_CONNECT_TIMEOUT_SECONDS=5
SOURCE_RETRIEVAL_TIMEOUT_SECONDS=15
SOURCE_RETRIEVAL_MAX_REDIRECTS=5
SOURCE_RETRIEVAL_MAX_BYTES=0
SOURCE_RETRIEVAL_ALLOWED_PORTS=80,443
SOURCE_RETRIEVAL_ROBOTS_POLICY=respect
SOURCE_RETRIEVAL_MAX_CANDIDATES_PER_COVERAGE_CELL=0
SOURCE_RETRIEVAL_MAX_CANDIDATES_PER_EXECUTION=0

# Real facility extraction (worker-connected; enable for staging + optional auto-publish)
FACILITY_EXTRACTION_ENABLED=true
FACILITY_EXTRACTION_MODEL=gpt-4.1
FACILITY_EXTRACTION_MAX_DOCUMENT_CHARACTERS=0
FACILITY_EXTRACTION_CHUNK_CHARACTERS=12000
FACILITY_EXTRACTION_CHUNK_OVERLAP_CHARACTERS=500
FACILITY_EXTRACTION_MAX_CHUNKS_PER_DOCUMENT=0
FACILITY_EXTRACTION_MAX_DOCUMENTS_PER_EXECUTION=0
FACILITY_EXTRACTION_MAX_CHUNKS_PER_EXECUTION=0
FACILITY_EXTRACTION_MAX_CANDIDATES_PER_CHUNK=0
FACILITY_EXTRACTION_MAX_CANDIDATES_PER_DOCUMENT=0
FACILITY_EXTRACTION_TIMEOUT_SECONDS=60
FACILITY_EXTRACTION_MAX_ATTEMPTS=2
FACILITY_EXTRACTION_MAX_OUTPUT_TOKENS=16384
FACILITY_EXTRACTION_MAX_EVIDENCE_QUOTE_CHARACTERS=1000

# Auto-publish verified staging candidates into final rehab facility tables
FACILITY_PUBLICATION_ENABLED=true
FACILITY_PUBLICATION_MIN_CONFIDENCE=0.55
FACILITY_PUBLICATION_MAX_CANDIDATES_PER_EXECUTION=0

# Optional source discovery provider — Brave Search (inactive unless selected)
BRAVE_SEARCH_API_KEY=
BRAVE_SEARCH_BASE_URL=https://api.search.brave.com/res/v1/web/search
BRAVE_SEARCH_TIMEOUT_SECONDS=20
BRAVE_SEARCH_RESULTS_PER_QUERY=10
BRAVE_SEARCH_MAX_QUERIES_PER_DISCOVERY=6

# Voice transcription — local development defaults use CPU
TRANSCRIPTION_ENABLED=true
TRANSCRIPTION_MODEL=large-v3-turbo
TRANSCRIPTION_DEVICE=cpu
TRANSCRIPTION_COMPUTE_TYPE=float16
TRANSCRIPTION_CPU_MODEL=medium
TRANSCRIPTION_CPU_COMPUTE_TYPE=int8
TRANSCRIPTION_STRICT_DEVICE=false
TRANSCRIPTION_MAX_DURATION_SECONDS=600
TRANSCRIPTION_MAX_UPLOAD_BYTES=26214400
TRANSCRIPTION_TIMEOUT_SECONDS=300
TRANSCRIPTION_TMP_DIR=/tmp/multimind-transcriptions
TRANSCRIPTION_CONCURRENCY=1
TRANSCRIPTION_MODEL_CACHE_DIR=/models/whisper
HF_HOME=/models/whisper
TRANSCRIPTION_BEAM_SIZE=1
TRANSCRIPTION_VAD_FILTER=true
TRANSCRIPTION_INITIAL_PROMPT=MultiMind, OpenRouter, Ollama, Claude, Gemini, GPT, RAG, orchestrator, scraper, blueprint, verdict, model set

# Production GPU example:
# TRANSCRIPTION_DEVICE=cuda
# TRANSCRIPTION_MODEL=large-v3-turbo
# TRANSCRIPTION_COMPUTE_TYPE=float16
# TRANSCRIPTION_STRICT_DEVICE=false

# Docker Compose (optional — loaded automatically)
# OPENROUTER_API_KEY is read from the host .env when running:
#   docker compose up --build
